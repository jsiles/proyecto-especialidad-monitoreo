# Backend API URL
VITE_API_URL=http://localhost:3000/api

# WebSocket server base URL (Socket.IO uses path /ws internally)
VITE_WS_URL=http://localhost:3000

# Grafana URL for embedded dashboards
VITE_GRAFANA_URL=/grafana

# Optional dev proxy target when running Vite outside Docker
VITE_GRAFANA_PROXY_TARGET=http://localhost:3001

# Environment
VITE_NODE_ENV=development

{
  "name": "monitoring-platform-backend",
  "version": "1.0.0",
  "description": "Backend API - Plataforma de Monitoreo en Tiempo Real",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migration:run": "ts-node src/database/migrate.ts",
    "seed": "ts-node src/database/seed.ts"
  },
  "dependencies": {
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "better-sqlite3": "^11.0.0",
    "winston": "^3.13.0",
    "nodemailer": "^6.9.0",
    "pdfkit": "^0.15.0",
    "socket.io": "^4.7.0",
    "axios": "^1.7.0",
    "zod": "^3.23.0",
    "express-rate-limit": "^7.3.0",
    "uuid": "^10.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.13.4",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "monitoring",
    "prometheus",
    "grafana",
    "asfi",
    "banking",
    "typescript",
    "express"
  ],
  "author": "Jorge Siles Zepita",
  "license": "MIT"
}

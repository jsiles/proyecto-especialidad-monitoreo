# ============================================
# Dockerfile.dev - Backend Development
# Hot reload with ts-node-dev
# ============================================

FROM node:20-alpine

WORKDIR /app

# Install build dependencies
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install all dependencies
RUN npm install

# Expose port
EXPOSE 3000

# Start with hot reload
CMD ["npm", "run", "dev"]
